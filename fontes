    </style>
</head>
<body>

<nav>
    <h1>Portal Aberto</h1>
    <button class="btn-post" onclick="addPost()">Nova Postagem +</button>
</nav>

<div class="grid" id="portalGrid">
    <div class="card">
        <div class="user-info">Postado por: Usuário_Anonimo</div>
        <h3 contenteditable="true">Notícia de Última Hora</h3>
        <p contenteditable="true">Qualquer pessoa pode clicar aqui e adicionar uma informação ou relato ao portal.</p>
    </div>
</div>

<script>
    function addPost() {
        const grid = document.getElementById('portalGrid');
        const newCard = document.createElement('div');
        newCard.className = 'card';
        newCard.innerHTML = `
            <div class="user-info">Postado por: Novo Membro</div>
            <h3 contenteditable="true">Título da sua contribuição</h3>
            <p contenteditable="true">Escreva sua notícia ou comentário aqui...</p>
        `;
        grid.prepend(newCard);
    }
</script>

</body>
</html>

